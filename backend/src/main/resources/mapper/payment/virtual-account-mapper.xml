<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.biddingmate.biddinggo.payment.mapper.VirtualAccountMapper">

    <insert id="insert" parameterType="VirtualAccount" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO virtual_account(
            payment_id,
            bank_code,
            bank_account,
            account_holder_name,
            due_date,
            created_at
        ) VALUES (
                     #{paymentId},
                     #{bankCode},
                     #{bankAccount},
                     #{accountHolderName},
                     #{dueDate},
                     #{createdAt}
                 )
    </insert>

</mapper>
