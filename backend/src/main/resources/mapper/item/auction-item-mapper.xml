<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.biddingmate.biddinggo.item.mapper.AuctionItemMapper">

    <resultMap id="auctionItemResultMap" type="AuctionItem">
        <id property="id" column="id"/>
        <result property="sellerId" column="seller_id"/>
        <result property="categoryId" column="category_id"/>
        <result property="brand" column="brand"/>
        <result property="name" column="name"/>
        <result property="quality" column="quality"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="inspectionStatus" column="inspection_status"/>
        <result property="returnedAt" column="returned_at"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findById" parameterType="long" resultMap="auctionItemResultMap">
        SELECT
            id,
            seller_id,
            category_id,
            brand,
            name,
            quality,
            description,
            status,
            inspection_status,
            returned_at,
            created_at
        FROM auction_item
        WHERE id = #{id}
    </select>

    <update id="updateStatus">
        UPDATE auction_item
        SET status = #{newStatus}
        WHERE id = #{itemId}
        <if test="currentStatus != null">
            AND status = #{currentStatus}
        </if>
        <if test="currentInspectionStatus != null">
            AND inspection_status = #{currentInspectionStatus}
        </if>
    </update>

    <insert id="insert" parameterType="AuctionItem" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO auction_item
        <trim prefix="(" suffix=")" suffixOverrides=",">
            seller_id,
            category_id,
            <if test="brand != null">brand,</if>
            name,
            <if test="quality != null">quality,</if>
            <if test="description != null">description,</if>
            <if test="status != null">status,</if>
            <if test="inspectionStatus != null">inspection_status,</if>
            <if test="returnedAt != null">returned_at,</if>
            created_at
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            #{sellerId},
            #{categoryId},
            <if test="brand != null">#{brand},</if>
            #{name},
            <if test="quality != null">#{quality},</if>
            <if test="description != null">#{description},</if>
            <if test="status != null">#{status},</if>
            <if test="inspectionStatus != null">#{inspectionStatus},</if>
            <if test="returnedAt != null">#{returnedAt},</if>
            #{createdAt}
        </trim>
    </insert>

    <update id="updateInspectionStatus">
        UPDATE auction_item
        <set>
            inspection_status = #{newStatus},
            <if test="newStatus.name() == 'PASSED' and quality != null">
                quality = #{quality},
            </if>
        </set>
        WHERE id = #{itemId}
        <if test="currentStatus != null">
            AND inspection_status = #{currentStatus}
        </if>
    </update>

    <update id="updateItemsStatusByAuctionIds">
        UPDATE auction_item ai
        JOIN auction a ON ai.id = a.item_id
        SET ai.status = #{status}
        WHERE a.id IN
        <foreach collection="auctionIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

</mapper>
